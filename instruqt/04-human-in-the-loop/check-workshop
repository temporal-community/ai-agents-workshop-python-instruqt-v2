#!/bin/bash
set -euo pipefail
COMPLETED=$(temporal workflow list \
    --address 127.0.0.1:7233 \
    --namespace default \
    --query 'TaskQueue="hitl-agent-python-task-queue" AND ExecutionStatus="Completed"' \
    --limit 1 2>/dev/null | grep -c "Completed" || true)
if [[ "${COMPLETED}" -lt 1 ]]; then
    echo "FAIL: No completed HITL workflows yet. Complete a full interaction and wait for the workflow to finish."
    exit 1
fi
echo "OK: At least one demo4 HITL workflow completed."
exit 0
