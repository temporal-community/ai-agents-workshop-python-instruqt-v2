#!/bin/bash
set -euo pipefail
COMPLETED=$(temporal workflow list \
    --address 127.0.0.1:7233 \
    --namespace default \
    --query 'TaskQueue="travel-planner-agent-tq" AND ExecutionStatus="Completed"' \
    --limit 5 2>/dev/null | grep -c "Completed" || true)
if [[ "${COMPLETED}" -lt 1 ]]; then
    echo "FAIL: No completed workflows on travel-planner-agent-tq. Start the Java worker and run a travel prompt."
    exit 1
fi
echo "OK: At least one TravelPlannerAgentWorkflow completed."
exit 0
