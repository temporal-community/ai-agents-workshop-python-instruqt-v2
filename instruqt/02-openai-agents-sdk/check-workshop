#!/bin/bash
set -euo pipefail
COMPLETED=$(temporal workflow list \
    --address 127.0.0.1:7233 \
    --namespace default \
    --query 'TaskQueue="openai-agents-python-task-queue" AND ExecutionStatus="Completed"' \
    --limit 1 2>/dev/null | grep -c "Completed" || true)
if [[ "${COMPLETED}" -lt 1 ]]; then
    echo "FAIL: No completed workflows on demo2 task queue. Run a workflow and wait for it to finish."
    exit 1
fi
echo "OK: At least one demo2 workflow completed."
exit 0
