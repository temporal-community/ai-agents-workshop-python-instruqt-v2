#!/bin/bash
set -euo pipefail
COMPLETED=$(temporal workflow list \
    --address 127.0.0.1:7233 \
    --namespace default \
    --query 'TaskQueue="orchestrator-tq" AND ExecutionStatus="Completed"' \
    --limit 5 2>/dev/null | grep -c "Completed" || true)
if [[ "${COMPLETED}" -lt 1 ]]; then
    echo "FAIL: No completed orchestrator workflows. Run a prompt that invokes the travel planner."
    exit 1
fi
echo "OK: At least one demo6a orchestrator workflow completed."
exit 0
