#!/bin/bash
# ABOUTME: Track-level setup. Runs once when the attendee enters the track.
# Everything heavy is baked into the image. This script only:
#   1. Stages /opt/workshop -> /root/workshop (attendee's writable copy)
#   2. Copies proxy state to a writable location
#   3. Starts background services
#   4. Waits for Temporal health
#   5. Registers Nexus endpoints
#   6. Bridges OPENAI_API_KEY secret into the attendee shell
set -euo pipefail

# 1. Stage workshop source into writable home directory.
if [ ! -d /root/workshop ]; then
    cp -r /opt/workshop /root/workshop
fi

# 2. Stage proxy state into writable location.
mkdir -p /root/proxy/static
cp -r /opt/proxy/* /root/proxy/

# 3. Start background services.
nohup mitmdump \
    --listen-port 8888 \
    --set block_global=false \
    --set ssl_insecure=false \
    -s /root/proxy/toggle_addon.py \
    > /tmp/proxy.log 2>&1 &

nohup /opt/mitmproxy-venv/bin/python /root/proxy/controlpanel.py \
    > /tmp/controlpanel.log 2>&1 &

nohup temporal server start-dev \
    --ip 0.0.0.0 \
    --db-filename /root/temporal.db \
    --log-level warn \
    > /tmp/temporal-server.log 2>&1 &

# code-server points at the attendee's writable workshop copy.
nohup code-server \
    --host 0.0.0.0 \
    --port 8080 \
    --auth none \
    /root/workshop \
    > /tmp/code-server.log 2>&1 &

# 4. Wait for Temporal health.
for i in $(seq 1 60); do
    if temporal operator cluster health --address 127.0.0.1:7233 >/dev/null 2>&1; then
        echo "Temporal server healthy."
        break
    fi
    sleep 1
done

# 5. Register Nexus endpoints (idempotent).
temporal operator nexus endpoint create \
    --name f1-expert \
    --target-namespace default \
    --target-task-queue f1-expert-agent-tq \
    --address 127.0.0.1:7233 || true

temporal operator nexus endpoint create \
    --name f1-expert-d6 \
    --target-namespace default \
    --target-task-queue f1-expert-agent-tq \
    --address 127.0.0.1:7233 || true

temporal operator nexus endpoint create \
    --name travel-planner \
    --target-namespace default \
    --target-task-queue travel-planner-agent-tq \
    --address 127.0.0.1:7233 || true

# 6. Bridge OPENAI_API_KEY secret into the attendee shell.
if [ -n "${OPENAI_API_KEY:-}" ]; then
    cat >> /root/.bashrc <<EOF
export OPENAI_API_KEY=${OPENAI_API_KEY}
EOF
    echo "OPENAI_API_KEY injected."
else
    echo "WARNING: OPENAI_API_KEY not set. Configure a secret in the Instruqt web UI."
fi

echo "==> Track setup complete."
